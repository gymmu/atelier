{
	"name": "atelier",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"main": "electron/main.cjs",
	"scripts": {
		"dev": "concurrently \"vite dev\" \"wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
		"build": "vite build",
		"preview": "vite preview",

		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"concurrently": "^9.2.1",
		"electron": "^41.0.4",
		"electron-builder": "^26.8.1",
		"svelte": "^5.54.0",
		"svelte-monaco": "^1.0.4",
		"vite": "^7.3.1",
		"wait-on": "^9.0.4"
	},
	"dependencies": {
		"csv-parse": "^6.2.1",
		"csv-stringify": "^6.7.0",
		"gray-matter": "^4.0.3",
		"marked": "^17.0.5",
		"yaml": "^2.8.3"
